{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "app-debug",
      "displayName": "App Debug",
      "description": "Configure the raylib visualization app and tests.",
      "binaryDir": "${sourceDir}/build/app-debug",
      "cacheVariables": {
        "MEMORY_PLAYGROUND_BUILD_APP": "ON",
        "MEMORY_PLAYGROUND_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "app-vcpkg-debug",
      "displayName": "App Debug with vcpkg",
      "description": "Configure the visualization app with the vcpkg toolchain. Requires VCPKG_ROOT.",
      "inherits": "app-debug",
      "binaryDir": "${sourceDir}/build/app-vcpkg-debug",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
    },
    {
      "name": "tests-debug",
      "displayName": "Tests Debug",
      "description": "Configure simulator tests only. raylib is not required.",
      "binaryDir": "${sourceDir}/build/tests-debug",
      "cacheVariables": {
        "MEMORY_PLAYGROUND_BUILD_APP": "OFF",
        "MEMORY_PLAYGROUND_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "app-debug",
      "configurePreset": "app-debug",
      "configuration": "Debug"
    },
    {
      "name": "app-vcpkg-debug",
      "configurePreset": "app-vcpkg-debug",
      "configuration": "Debug"
    },
    {
      "name": "tests-debug",
      "configurePreset": "tests-debug",
      "configuration": "Debug",
      "targets": [
        "memory-playground-tests"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "tests-debug",
      "configurePreset": "tests-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
